# Copier vers .env sur le VPS : cp .env.example .env

NODE_ENV=production
PORT=3000
HOST_PORT=3000

# PostgreSQL (ex. Neon)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Secrets (générer des valeurs longues et aléatoires)
JWT_SECRET=remplacer-par-une-chaine-secrete-longue
SESSION_SECRET=remplacer-par-une-autre-chaine-secrete

# Firebase FCM — JSON service account sur une ligne (jq -c . fichier.json)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"votre-projet",...}

# Alternative : chemin vers un fichier JSON (prioritaire si défini)
# FIREBASE_SERVICE_ACCOUNT_PATH=/app/firebase-adminsdk.json
